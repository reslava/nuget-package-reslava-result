<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>

    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CompilerGeneratedFilesOutputPath>$(ProjectDir)GeneratedFiles</CompilerGeneratedFilesOutputPath>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="MSTest" Version="4.0.1" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="18.0.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.0.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces" Version="5.0.0" />
    <PackageReference Include="coverlet.collector" Version="6.0.2">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
  </ItemGroup>

  <ItemGroup>
    <!-- Generator under test -->
    <ProjectReference Include="..\..\src\REslava.Result.Flow\REslava.Result.Flow.csproj" />
    <!-- REslava.Result — needed so typeof(IResultBase).Assembly.Location is available for test compilations -->
    <ProjectReference Include="..\..\src\REslava.Result\REslava.Result.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Using Include="Microsoft.VisualStudio.TestTools.UnitTesting" />
    <Using Include="Microsoft.CodeAnalysis" />
    <Using Include="Microsoft.CodeAnalysis.CSharp" />
    <Using Include="Microsoft.CodeAnalysis.Text" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="ResultFlowAnalyzerTests.cs" />
    <Compile Include="ResultFlowGeneratorTests.cs" />
    <Compile Include="ResultFlowDiagramDeliveryTests.cs" />
    <Compile Include="ResultFlowCrossMethodTests.cs" />
    <Compile Include="ResultFlowLayerViewTests.cs" />
    <Compile Include="ResultFlowStatsTests.cs" />
    <Compile Include="ResultFlowErrorSurfaceTests.cs" />
    <Compile Include="ResultFlowErrorPropagationTests.cs" />
    <Compile Include="ResultFlowLayerDetectionTests.cs" />
    <Compile Include="ResultFlowMultiBranchTests.cs" />
    <Compile Include="ResultFlowThemeTests.cs" />
    <Compile Include="ResultFlowDefaultThemeTests.cs" />
    <Compile Include="ResultFlowRegistryGeneratorTests.cs" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="$(CompilerGeneratedFilesOutputPath)\**\*.g.cs" />
  </ItemGroup>

  <ItemGroup Condition="'$(Configuration)' == 'Debug'">
    <Compile Remove="GeneratedFiles\**\*.g.cs" />
    <Compile Remove="obj\**\*.g.cs" />
  </ItemGroup>

</Project>
