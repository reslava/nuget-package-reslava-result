{
  "name": "reslava-result-extensions",
  "displayName": "REslava.Result Extensions",
  "description": "CodeLens and diagram preview for [ResultFlow] pipelines",
  "version": "1.1.1",
  "publisher": "reslava",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/reslava/nuget-package-reslava-result" },
  "icon": "images/icon.png",
  "engines": { "vscode": "^1.78.0" },
  "categories": ["Visualization"],
  "keywords": ["mermaid", "result", "csharp", "dotnet", "pipeline", "diagram", "flowchart", "codelens", "resultflow", "reslava"],
  "activationEvents": ["onLanguage:csharp"],
  "main": "./out/extension.js",
  "contributes": {},
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.78.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^3.0.0"
  }
}
