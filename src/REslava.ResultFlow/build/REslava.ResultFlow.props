<Project>
  <PropertyGroup>
    <!-- Mark this as a source generator for better IDE support -->
    <IsRoslynComponent>true</IsRoslynComponent>
  </PropertyGroup>

  <!-- Ensure the generator is loaded -->
  <ItemGroup>
    <Analyzer Include="$(MSBuildThisFileDirectory)..\analyzers\dotnet\cs\REslava.ResultFlow.dll" />
  </ItemGroup>

  <!-- Expose MSBuild properties to the generator via AnalyzerConfigOptionsProvider -->
  <ItemGroup>
    <CompilerVisibleProperty Include="ResultFlowDefaultTheme" />
    <CompilerVisibleProperty Include="ResultFlowRegistry" />
  </ItemGroup>
</Project>
